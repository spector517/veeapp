{
  "name": "veeapp-sdk",
  "version": "0.1.0",
  "description": "Auto-generated TypeScript/Axios SDK for VeeApp Backend API",
  "private": true,
  "scripts": {
    "generate": "openapi-generator-cli generate -i openapi.yaml -g typescript-axios -o src --additional-properties=supportsES6=true,withSeparateModelsAndApi=true,apiPackage=api,modelPackage=model"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.13.0"
  }
}